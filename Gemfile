source "https://rubygems.org"

# Run the site locally with:  bundle exec jekyll serve
gem "jekyll", "~> 3.10.0"
gem "github-pages", "~> 232", group: :jekyll_plugins
# webrick is no longer bundled with Ruby 3.0+ and Jekyll's local server needs it
gem "webrick", "~> 1.8"
gem 'jekyll-sitemap'
# No custom plugins are used, so this theme also builds as-is on GitHub Pages.
# If you deploy via GitHub Pages' built-in build (not Actions), you can instead
# comment out the lines above and use:
#   gem "github-pages", group: :jekyll_plugins
